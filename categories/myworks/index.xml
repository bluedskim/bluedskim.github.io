    <item>
      <title>Fly me to the moon</title>
      <link>https://bluedskim.github.io/posts/myworks/fly-me-to-the-moon/</link>
      <pubDate>Mon, 30 Jan 2006 14:27:00 +0900</pubDate>
      <guid>https://bluedskim.github.io/posts/myworks/fly-me-to-the-moon/</guid>
